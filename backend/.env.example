# Backend Environment Variables Example
# Copy this file to .env and update with your values
# REQUIRED: All variables marked as REQUIRED must be set before starting the server

# Server Configuration
# For local development (non-Docker). Docker Compose overrides this to 8000 via its environment block.
PORT=3001
NODE_ENV=development

# Database Configuration (REQUIRED)
# PostgreSQL connection string - MUST be set, no fallback provided
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://stellarguard:password@localhost:5432/stellarguard

# Alternative database configuration (used by Docker Compose)
POSTGRES_USER=stellarguard
POSTGRES_PASSWORD=password
POSTGRES_DB=stellarguard

# Redis Configuration (optional - for caching/sessions)
REDIS_URL=redis://localhost:6379

# Stellar Configuration (REQUIRED)
# Stellar network: testnet, futurenet, or mainnet
STELLAR_NETWORK=testnet

# Soroban RPC endpoint - MUST be set, no fallback provided
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Horizon API endpoint (for Stellar classic operations)
HORIZON_URL=https://horizon-testnet.stellar.org

# Network passphrase - MUST be set, no fallback provided
# Testnet: "Test SDF Network ; September 2015"
# Mainnet: "Public Global Stellar Network ; September 2015"
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Contract IDs (optional but recommended)
# Populate these after deploying your smart contracts
# At least one contract ID should be configured for full functionality
TREASURY_CONTRACT_ID=
GOVERNANCE_CONTRACT_ID=
TOKEN_VAULT_CONTRACT_ID=
ACCESS_CONTROL_CONTRACT_ID=

# API Configuration
# Polling interval for contract events (milliseconds)
POLL_INTERVAL_MS=5000

# CORS origin - comma-separated list of allowed origins
# In production, avoid using "*" for security
CORS_ORIGIN=http://localhost:3000

# Database pool configuration
DB_POOL_MAX=10

# Security Configuration
# API Keys for write operations (comma-separated for multiple keys)
# Leave empty in development to allow all requests
# In production, set strong API keys to protect write endpoints
# Example: API_KEYS=key1,key2,key3
API_KEYS=

# Rate limiting is configured in app.module.ts (default: 100 req/min per IP)

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Development
DEBUG=stellarguard:*
